# Copy to `.env` in this directory and adjust values.
# Application reads `api/.env` automatically (path fixed relative to package).

# Required — Neon: copy the full connection string from the Neon dashboard.
# Do NOT leave the literal word HOST here — use your real hostname (ep-....neon.tech).
# `postgresql://` is OK; the app rewrites it to use the psycopg v3 driver.
DATABASE_URL=postgresql+psycopg://neon:npg_xxxxxxxx@ep-cool-name-123456.us-east-2.aws.neon.tech/neondb?sslmode=require

# development | production (enables reload for `python -m app` when development)
APP_ENV=development

# URL prefix for all routes (default /api)
API_PREFIX=/api

# Max upload size in bytes (default 1048576 = 1 MB)
MAX_UPLOAD_BYTES=1048576

# Secret key length for new boxes (alphanumeric)
BOX_SECRET_KEY_LENGTH=8

# CORS: comma-separated origins, or * for any
CORS_ORIGINS=*

# Optional: comma-separated hosts for TrustedHostMiddleware (leave empty to disable)
# TRUSTED_HOSTS=api.example.com,localhost

LOG_LEVEL=INFO

# Set false in production if you do not want Swagger UI
DOCS_ENABLED=true

# Set false in production when using Alembic/migrations only
AUTO_CREATE_TABLES=false

SQLALCHEMY_POOL_SIZE=5
SQLALCHEMY_MAX_OVERFLOW=10
SQLALCHEMY_POOL_TIMEOUT=30

# Upload token lifetime in hours
TOKEN_TTL_HOURS=720

# Comma-separated allowlist of persisted MIME types
ALLOWED_UPLOAD_MIME_TYPES=image/png,image/jpeg,image/gif,text/plain,application/octet-stream,binary/octet-stream

# Lightweight in-process rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60

# Add basic hardening headers to responses
SECURITY_HEADERS_ENABLED=true

# Trust X-Forwarded-For when behind a reverse proxy
TRUST_PROXY_HEADERS=true

# Used only by `python -m app` (avoid names HOST/PORT alone — they confused DB URLs)
UVICORN_HOST=0.0.0.0
UVICORN_PORT=9017
